---
import "../styles/global.css";
import type { BaseFrontmatter } from "../types";

import "katex/dist/katex.min.css";
import { SEO } from "astro-seo";
import { ClientRouter } from "astro:transitions";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Main from "../components/Main.astro";
const { frontmatter } = Astro.props as { frontmatter: BaseFrontmatter };
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />

        <link rel="icon" type="image/png" href="/images/icon.png" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap"
            rel="stylesheet"
        />

        <SEO
            title={`${frontmatter.title} | Siriuns' blog`}
            description={frontmatter.description ?? "Null Description"}
            openGraph={{
                basic: {
                    title: `${frontmatter.title} | Siriuns' blog`,
                    type: "article",
                    image: "https://siriuns.netlify.app/images/og-image.jpg",
                },
                optional: {
                    description: frontmatter.description ?? "Null Description",
                },
            }}
        />

        <ClientRouter />
    </head>

    <body>
        <Header />
        <Main>
            <slot />
        </Main>
        <Footer />
    </body>
</html>
