---
// src/pages/tags/[tag].astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import GlassCard from "../../components/GlassCard.astro";
import type { Post } from "../../types";

export async function getStaticPaths() {
    const allPosts = Object.values(
        import.meta.glob<Post>("../posts/*.md", { eager: true }),
    );

    const uniqueTags = [
        ...new Set(allPosts.map((post) => post.frontmatter.tags).flat()),
    ];

    const sortedPosts = allPosts.toSorted(
        (a, b) =>
            new Date(b.frontmatter.pubDate).getTime() -
            new Date(a.frontmatter.pubDate).getTime(),
    );

    return uniqueTags.map((tag) => {
        return {
            params: { tag },
            props: {
                filteredPosts: sortedPosts.filter((post) =>
                    post.frontmatter.tags.includes(tag),
                ),
            },
        };
    });
}

const { tag } = Astro.params;
const { filteredPosts } = Astro.props;
---

<BaseLayout frontmatter={{ title: `tag: ${tag}` }}>
    {
        filteredPosts.map((post) => (
            <GlassCard
                href={post.url}
                title={post.frontmatter.title}
                description={`Published on: ${post.frontmatter.pubDate.toString().slice(0, 10)}`}
            />
        ))
    }
</BaseLayout>
