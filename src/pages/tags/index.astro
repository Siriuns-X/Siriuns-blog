---
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { Post } from "../../types";
const title = "Tags List";

const allPosts = Object.values(
    import.meta.glob("../posts/*.md", { eager: true }),
) as Post[];

const tagCounts = allPosts.reduce((acc, post) => {
    post.frontmatter.tags.forEach((tag) => {
        acc.set(tag, (acc.get(tag) || 0) + 1);
    });
    return acc;
}, new Map<string, number>());

const uniqueTags = [...tagCounts.keys()].sort(
    (a, b) => (tagCounts.get(b) || 0) - (tagCounts.get(a) || 0),
);
---

<BaseLayout frontmatter={{ title }}>
    {
        uniqueTags.map((tag) => (
            <a class="main__content--card glass-card" href={`/tags/${tag}`}>
                <h1>{tag}</h1>
                <p>Articles with this tag: {tagCounts.get(tag)}</p>
            </a>
        ))
    }
</BaseLayout>
